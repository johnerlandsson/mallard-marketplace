      "id": "net.mallard.discworld-magic",
      "name": "Discworld Magic",
      "description": "Colour highlights and inline annotations for Discworld magic spell output.",
      "language": "lua",
      "homepage": "https://github.com/wizardquack/mallardx-discworld-magic",
